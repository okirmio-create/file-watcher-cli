  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "minimatch": "^9.0.9"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
